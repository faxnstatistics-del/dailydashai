# Neon PostgreSQL (use your connection string from the Neon console)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js / NextAuth — use a long random secret in production
# Example shape (replace with your own): smk_2108_A7
AUTH_SECRET="smk_2108_A7"
AUTH_URL="http://localhost:3000"

# Optional legacy names (Auth.js also reads these):
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

OPENAI_API_KEY=""
